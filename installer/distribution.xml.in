<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>mSL/XNU __MSLVERSION__</title>
    <organization>com.beako.msl</organization>
    <options customize="never" require-scripts="true"
             hostArchitectures="arm64,x86_64" rootVolumeOnly="true"/>

    <welcome    file="welcome.html"    mime-type="text/html"/>
    <license    file="LICENSE"         mime-type="text/plain"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <choices-outline>
        <line choice="default">
            <line choice="msl"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="msl" title="mSL/XNU" visible="false">
        <pkg-ref id="com.beako.msl.pkg"/>
    </choice>

    <pkg-ref id="com.beako.msl.pkg" version="__MSLVERSION__"
             onConclusion="none">msl-component.pkg</pkg-ref>
</installer-gui-script>
