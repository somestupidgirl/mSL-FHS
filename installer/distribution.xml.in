<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>mSL/FHS __FHSVERSION__</title>
    <organization>com.beako.fhs</organization>
    <options customize="never" require-scripts="true"
             hostArchitectures="arm64,x86_64" rootVolumeOnly="true"/>

    <welcome    file="welcome.html"    mime-type="text/html"/>
    <license    file="LICENSE"         mime-type="text/plain"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <choices-outline>
        <line choice="default">
            <line choice="fhs"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="fhs" title="mSL/FHS" visible="false">
        <pkg-ref id="com.beako.fhs.pkg"/>
    </choice>

    <pkg-ref id="com.beako.fhs.pkg" version="__FHSVERSION__"
             onConclusion="none">fhs-component.pkg</pkg-ref>
</installer-gui-script>
